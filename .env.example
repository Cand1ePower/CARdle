# CARdle 环境变量配置
# =============================================
# 将此文件重命名为 .env，填入真实的配置值。
# .env 文件已被 .gitignore 排除，不会上传到 GitHub。
# =============================================

# ── 大模型 API 配置 ──
API_KEY=sk-your-api-key-here
BASE_URL=https://api.deepseek.com
MODEL_ENDPOINT=deepseek-chat

# ── 高德地图 API ──
AMAP_MAPS_API_KEY=your-amap-key-here

# ── Redis 配置 ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=           # 若 Redis 设置了密码，在此填写

# Langfuse 可观测性平台配置 (申请地址: https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_HOST="https://cloud.langfuse.com"
# ── 微服务地址 ──
REWRITE_URL=http://127.0.0.1:8006/rewrite-server/v1
REJECT_URL=http://127.0.0.1:8007/reject-server/v1
INTENT_URL=http://127.0.0.1:8008/intent-server/v1
CORR_URL=http://127.0.0.1:8009/correlation-server/v1

# ── 超时配置 ──
REQUEST_TIMEOUT=3.0
